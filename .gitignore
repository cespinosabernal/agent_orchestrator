# OS
.DS_Store
Thumbs.db

# Project repos (cloned into repo/ — each is its own git repo)
repo/

# Skill symlinks (activated on demand; not committed)
.claude/skills/*
!.claude/skills/.gitkeep

# Memory, planning, retrospectives, and handoffs (local session state)
.claude/memory/*
!.claude/memory/.gitkeep
.claude/planning/*
!.claude/planning/.gitkeep
.claude/retrospectives/*
!.claude/retrospectives/.gitkeep
.claude/handoffs/*
!.claude/handoffs/.gitkeep

# Python environments and caches
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.python-version
*.egg-info/
dist/
build/

# Jupyter
.ipynb_checkpoints/
*.ipynb output cells (run `jupyter nbconvert --clear-output` before committing)

# Package management
pyproject.toml
uv.lock

# Environment variables and secrets
.env
.env.*
*.pem
*.key

